#!/bin/sh
set -e

PATH="/rescue"

echo "==> Remount rootfs RW"
mount -u -w /

echo "==> Detect ISO"
ISO_DEV=$(ls /dev/iso9660 2>/dev/null | head -n 1)

if [ -z "$ISO_DEV" ]; then
  echo "No ISO found"
  exit 1
fi

echo "==> Mount CDROM"
mkdir -p /cdrom
mount_cd9660 /dev/iso9660/${ISO_DEV} /cdrom

# memory check
realmem=$(sysctl -n hw.realmem)
mem_gb=$((realmem / 1024 / 1024 / 1024))

if [ "$mem_gb" -lt 4 ]; then
  echo "Need at least 4GB RAM"
  exit 1
fi

echo "==> Create swap md"
md=$(mdconfig -a -t swap -s $((mem_gb * 75 / 100))g)

echo "==> Create ZFS pool"
zpool create -f -O compression=zstd livecd /dev/${md}

echo "==> Load system image"
zfs receive -F livecd < /cdrom/data/system.img

exec /rescue/sh
