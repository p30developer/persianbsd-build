#!/rescue/sh
set -e

echo "==> Checking memdisk"
ls /dev/md* >/dev/null 2>&1 || halt -p

echo "==> Clearing kernel env"
kenv -u init_chroot
kenv -u init_path
kenv -u init_script
kenv -u init_shell
kenv -u vfs.root.mountfrom || true

echo "==> Unmounting CDROM"
umount -f /cdrom || true

echo "==> Exporting ZFS pool"
zpool export -f livecd || true

echo "==> Setting root"
kenv vfs.root.mountfrom=zfs:livecd

echo "==> Reboot into new root"
reboot -r
